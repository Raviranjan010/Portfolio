PORT=5000
MONGO_URI=mongodb://localhost:27017/portfolio

# Frontend origin allowed by CORS (single URL)
CLIENT_URL=http://localhost:8080

# Optional: comma-separated additional allowed origins
# CLIENT_URLS=http://localhost:5173,https://your-frontend-domain.vercel.app

# SMTP (for contact email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Contact delivery settings
CONTACT_TO_EMAIL=your-email@gmail.com
CONTACT_FROM_NAME=Portfolio Contact
!
